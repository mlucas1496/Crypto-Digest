# No API key needed — uses Claude Code CLI (OAuth auth via `claude` CLI tool)

# Optional: SSL cert for corporate proxies that perform SSL inspection (e.g. Zscaler)
# NODE_EXTRA_CA_CERTS=/path/to/your/corporate-cert.pem
# REQUESTS_CA_BUNDLE=/path/to/your/corporate-cert.pem

# Schedule — America/New_York (EST/EDT auto-adjusts for daylight saving)
DIGEST_HOUR=7
DIGEST_MINUTE=30
DIGEST_TIMEZONE=America/New_York

# Sources to enable (comma-separated, no spaces)
ENABLED_SOURCES=milkroad,globenewswire,coindesk,cointelegraph,decrypt,theblock,wsj,bitcoinmagazine,googlenews

# GlobeNewswire keyword filter (comma-separated)
GNW_KEYWORDS=bitcoin,crypto,blockchain,ethereum,defi,stablecoin,digital asset,web3,nft,coinbase,binance,ripple,solana,polygon

# Digest settings
MAX_ARTICLES_PER_CATEGORY=5
LOOKBACK_HOURS=24

# Server
FLASK_PORT=8080
FLASK_DEBUG=false
